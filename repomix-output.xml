/* ─────────────────────────────────────────────────────────────
   Portfolio Type Definitions
───────────────────────────────────────────────────────────── */

/* ── Navigation ──────────────────────────────────────────── */
export interface NavLink {
  label: string;
  href: string;
}

/* ── Projects ────────────────────────────────────────────── */
export type ProjectTag =
  | "All"
  | "Full-Stack"
  | "ML/DL"
  | "UI/UX"
  | "Open Source";

export interface Project {
  id: string;
  title: string;
  tagline: string;
  description: string;
  tags: ProjectTag[];
  techStack: string[];
  image: string;         // path in /public/images/
  liveUrl?: string;
  githubUrl?: string;
  featured: boolean;
  year: number;
  isOngoing?: boolean;
}

